{
  "snowflake": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "--python",
      "3.12",
      "--python-preference=managed",
      "--from",
      "git+https://github.com/Snowflake-Labs/mcp",
      "mcp-server-snowflake",
      "--service-config-file",
      "~/.config/mcp/snowflake-config.yaml",
      "--authenticator",
      "externalbrowser",
      "--transport",
      "stdio"
    ],
    "env": {
      "SNOWFLAKE_ACCOUNT": "sza96462.us-east-1",
      "SNOWFLAKE_USER": "annosuke.yokoo@datadoghq.com",
      "SNOWFLAKE_DATABASE": "REPORTING"
    }
  },
  "datadog-mcp": {
    "type": "http",
    "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp"
  },
  "atlassian": {
    "type": "http",
    "url": "https://mcp.atlassian.com/v1/mcp"
  },
  "glean_default": {
    "type": "http",
    "url": "https://datadog-be.glean.com/mcp/default"
  },
  "aws-knowledge": {
    "type": "http",
    "url": "https://knowledge-mcp.global.api.aws"
  },
  "drawio": {
    "type": "stdio",
    "command": "npx",
    "args": [
      "-y",
      "@drawio/mcp"
    ]
  },
  "obsidian-mcp-tools": {
    "type": "stdio",
    "command": "${HOME}/Documents/Obsidian Vault/.obsidian/plugins/mcp-tools/bin/mcp-server",
    "args": [],
    "env": {
      "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}"
    }
  }
}

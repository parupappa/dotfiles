[include]
path = ~/dotfiles/git/user.conf

[core]
# エディタをvscodeに設定
editor = code --wait
	hooksPath = /usr/local/dd/global_hooks

[alias]
a = add
c = commit
br = branch
co = checkout
st = status

[init]
defaultBranch = main

[fetch]
prune = true

[pull]
ff = only
rebase = true

[http]
postBuffer = 157286400
[user]
	name = annosuke.yokoo
	email = annosuke.yokoo@datadoghq.com
[credential "https://github.com"]
	helper = 
	helper = !/Users/annosuke.yokoo/.local/share/mise/installs/gh/2.74.2/gh_2.74.2_macOS_arm64/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/Users/annosuke.yokoo/.local/share/mise/installs/gh/2.74.2/gh_2.74.2_macOS_arm64/bin/gh auth git-credential
